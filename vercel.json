{
  "version": 2,
  "builds": [
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "dist/client/assets/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "dist/client/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dist/server/server.js"
    }
  ]
}