{
  "version": 2,
  "builds": [
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/portfolio-source/assets/:path*", "destination": "/dist/client/assets/:path*" },
    { "source": "/portfolio-source/images/:path*", "destination": "/dist/client/images/:path*" },
    { "source": "/assets/:path*", "destination": "/dist/client/assets/:path*" },
    { "source": "/images/:path*", "destination": "/dist/client/images/:path*" },
    { "source": "/:path*", "destination": "/dist/server/server.js" }
  ]
}